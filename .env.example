# ─────────────────────────────────────────────────────────────────────────────
# Copier vers .env (jamais commité) et renseigner. Toutes les variables sont
# optionnelles : sans .env, l'app tourne en local sur SQLite, auth désactivée.
# ─────────────────────────────────────────────────────────────────────────────

# ── Recherche ───────────────────────────────────────────────────────────────
# Mots-clés LinkedIn (séparés par des virgules). Vide = valeurs par défaut du code.
# KEYWORDS=stage data analyst sport, stage python data sport, stage data ASO
LOCATION=France

# ── Authentification API ─────────────────────────────────────────────────────
# Mot de passe d'accès au dashboard. Vide = API ouverte (pratique en dev local).
# ⚠️ À définir en prod (Vercel) pour protéger les données.
# APP_PASSWORD=

# ── Scoring IA — Gemini ──────────────────────────────────────────────────────
# Clé gratuite : https://aistudio.google.com/app/apikey
SCORING_ENABLED=true
# GEMINI_API_KEY=
# Clés supplémentaires (autres comptes Google) séparées par des virgules → le
# tagger bascule sur la suivante quand une épuise son quota journalier (×N le quota).
# GEMINI_API_KEYS=cle2,cle3
GEMINI_MODEL=gemini-2.5-flash
# Quota journalier estimé (par clé : flash free tier = 20 RPD). Sert à l'estimation
# "jours restants" de l'État des lieux. ~35 observé avec 3 clés en rotation.
# GEMINI_DAILY_QUOTA=35
# Seuil heuristique sous lequel Gemini n'est PAS appelé (économie de quota). 0 = tout tagger.
# GEMINI_MIN_HEURISTIC=25

# ── LinkedIn (source active, endpoint public "guest") ────────────────────────
LINKEDIN_ENABLED=true
LINKEDIN_MAX_PER_KEYWORD=25
# Filtre niveau d'expérience (1=stage, 2=débutant). Filtre date (r2592000=30j).
# LINKEDIN_EXPERIENCE_LEVEL=1,2
# LINKEDIN_DATE_POSTED=r2592000

# ── Autres sources (désactivées — focus LinkedIn ; code conservé) ────────────
WTTJ_ENABLED=false          # gated login + AWS WAF, non scrapable actuellement
SMARTRECRUITERS_ENABLED=false
GREENHOUSE_ENABLED=false
WORKDAY_ENABLED=false
JOBTEASER_ENABLED=false

# ── Notifications Telegram ───────────────────────────────────────────────────
# 1) @BotFather -> /newbot -> token   2) api.telegram.org/bot<token>/getUpdates -> chat.id
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DASHBOARD_URL=https://mon-dashboard.vercel.app

# ── Stockage ─────────────────────────────────────────────────────────────────
DB_PATH=backend/db/jobs.db
# Turso (libSQL) — base distante persistante en prod. Laisser vide en local.
# TURSO_DATABASE_URL=libsql://internship-seeker-xxxx.turso.io
# TURSO_AUTH_TOKEN=
