# Recherche
KEYWORDS=data analyst, data engineer, business analyst, sport, événementiel
LOCATION=France

# LinkedIn (endpoint public "guest", source principale)
LINKEDIN_ENABLED=true
LINKEDIN_MAX_PER_KEYWORD=25
LINKEDIN_FETCH_DESCRIPTIONS=true
LINKEDIN_MAX_DESCRIPTIONS=50
# Filtre niveau d'expérience LinkedIn: 1=stage, 2=débutant (laisser vide = tout)
# LINKEDIN_EXPERIENCE_LEVEL=1

# The Muse (gratuite, sans clé) — socle de secours
THEMUSE_ENABLED=false
# THEMUSE_API_KEY=

# Welcome to the Jungle (via API Algolia publique)
WTTJ_ENABLED=true
WTTJ_MAX_PER_KEYWORD=50

# JobTeaser (scraping HTML — stages étudiants/jeunes diplômés)
JOBTEASER_ENABLED=true
JOBTEASER_MAX_PER_KEYWORD=50

# Scoring IA + extraction — Gemini (clé gratuite: https://aistudio.google.com/app/apikey)
SCORING_ENABLED=true
# GEMINI_API_KEY=
# Free tier réel (depuis déc. 2025) : flash-lite = 15 RPM / 1 000 RPD ;
# flash = 10 RPM / 250 RPD. On prend flash-lite pour 4× le quota journalier.
GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_DAILY_QUOTA=1000   # RPD du modèle ci-dessus (estimation jours restants)

# Notifications Telegram (Sprint 5)
# 1) @BotFather -> /newbot -> copier le token
# 2) parler à son bot, puis api.telegram.org/bot<token>/getUpdates -> chat.id
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DASHBOARD_URL=https://mon-dashboard.vercel.app

# Stockage
DB_PATH=backend/db/jobs.db
# Turso (libSQL) — base distante persistante (déploiement). Laisser vide en local.
# turso db create internship-seeker ; turso db show --url ; turso db tokens create internship-seeker
# TURSO_DATABASE_URL=libsql://internship-seeker-xxxx.turso.io
# TURSO_AUTH_TOKEN=
