# Exclure la base SQLite locale — en production on utilise Turso (TURSO_DATABASE_URL)
backend/db/*.db

# requirements.txt racine = pour GitHub Actions uniquement. S'il est présent,
# Vercel détecte un projet Python et ignore le build statique du frontend.
# La fonction serverless utilise api/requirements.txt.
/requirements.txt

# Inutile en production
.venv/
__pycache__/
*.pyc
.env

# Ce projet Vercel = API Python uniquement. Le frontend est un projet Vercel séparé
# (déployé depuis frontend/). On l'exclut ici pour garder la fonction serverless légère.
frontend/
node_modules/
